<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ninimum.api.region.service.RegionMapper">

    <select id="selectActiveRegions" resultType="camelMap">
        <![CDATA[
            SELECT
                id,
                name,
                is_active
            FROM regions
            WHERE is_active = TRUE
            ORDER BY name ASC
        ]]>
    </select>

</mapper>